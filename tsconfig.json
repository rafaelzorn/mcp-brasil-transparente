{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./build",

    "module": "commonjs",
    "target": "ES2020",

    "types": ["node"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "baseUrl": "src",
    "paths": {
      "@/*": ["*"]
    },

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,

    "isolatedModules": true,
    "skipLibCheck": true
  }
}
